# Vercel ignore file - Optimized for deployment
# Ignore development files and directories

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js
.next/
out/

# Environment files (keep example)
.env*
!.env.example

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Build artifacts
dist/
build/

# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/
.nyc_output/

# Dependency directories
jspm_packages/
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Cache directories
.cache
.parcel-cache

# Build outputs
.next
.nuxt
.vuepress/dist

# Serverless directories
.serverless

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# VSCode test
.vscode-test

# Whitelabel starter (not needed for main app)
whitelabel-starter/

# Programs directory (Solana programs)
programs/
programs-loan/

# Target directory (Rust build artifacts)
target/

# Docker files
Dockerfile
docker-dev.sh

# Scripts (needed for build)
# scripts/

# Documentation (keep README)
*.md
!README.md

# Lock files (keep package-lock.json)
yarn.lock
pnpm-lock.yaml

# TypeScript build info
tsconfig.tsbuildinfo